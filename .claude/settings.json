{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(flutter clean:*)",
      "Bash(flutter pub:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter run:*)",
      "Bash(flutter build:*)",
      "Bash(flutter doctor:*)",
      "Bash(dart format:*)",
      "Bash(dart fix:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(adb devices:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -qE '\\.dart$'; then dart format \"$CLAUDE_FILE_PATHS\" 2>/dev/null && echo '✓ formatted'; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -q 'verified_quran.dart'; then echo '⚠️  WARNING: verified_quran.dart was modified. Verify Quran text against Tanzil before commit.' >&2; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'rm -rf (/|~|\\$HOME|assets/audio)'; then echo '🛑 BLOCKED: dangerous rm command' >&2; exit 2; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '🟢 Ruqyah Altatil — Flutter project loaded. Read CLAUDE.md for conventions.'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
